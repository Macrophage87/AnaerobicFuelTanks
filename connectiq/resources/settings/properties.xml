<properties>
    <!-- #42: CP/W' default to the SENTINEL 0 (Monkey C requires a default for numeric properties,
         so a null/empty default won't compile). 0 is below the settings-UI minimums (CP >= 50,
         W' >= 1000), so a stored 0 unambiguously means "never configured" and lets the "SET CP/W'"
         guard distinguish "unset" from "provided". (The former 250/20000 defaults made mConfigured
         always true and the guard dead.) reloadSettings() maps a 0/unset value to the model's safe
         250/20000 fallback; isConfigured() treats <=0 (or null) as not-provided. -->
    <property id="CP"      type="number">0</property>
    <property id="Wprime"  type="number">0</property>
    <property id="fP"      type="float">0.25</property>
    <property id="pPmax"   type="number">300</property>
    <property id="tauP"    type="number">27</property>
    <property id="tauG"    type="number">470</property>
    <property id="lt1Frac" type="float">0.80</property>
    <property id="eta"     type="float">1.00</property>
    <property id="fatK"    type="float">0.75</property>
    <property id="gFat"    type="float">0.00</property>
    <property id="tauAer"  type="number">25</property>
    <property id="tauOn"   type="number">6</property>
</properties>
